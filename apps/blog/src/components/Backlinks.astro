---
import type { Backlink } from "../lib/public-link-index";

const { backlinks } = Astro.props as { backlinks: Backlink[] };
const primaryBacklink = backlinks[0];
const extraCount = Math.max(0, backlinks.length - 1);
---
{
  primaryBacklink && (
    <section class="backlinks-compact" aria-labelledby="backlinks-title">
      <h2 class="backlinks-compact-title" id="backlinks-title">Backlinks</h2>
      <a class="backlinks-compact-link" href={primaryBacklink.source.href}>
        <span class="backlinks-compact-source">{primaryBacklink.source.title}</span>
        {extraCount > 0 && <small class="backlinks-compact-count">+{extraCount}</small>}
      </a>
    </section>
  )
}
