---
import { ui } from "../lib/ui-classes";

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

const { headings } = Astro.props as { headings: Heading[] };
const eligible = headings.filter((heading) => heading.depth === 2 || heading.depth === 3);
---
{
  eligible.length > 0 && (
    <nav class={ui.toc} aria-labelledby="toc-title">
      <h2 class={ui.tocTitle} id="toc-title">Contents</h2>
      <ol class={ui.tocList}>
        {eligible.map((heading) => (
          <li class:list={[ui.tocItem, heading.depth === 3 && ui.tocItemNested, `depth-${heading.depth}`]}>
            <a class={heading.depth === 3 ? ui.tocLinkNested : ui.tocLink} href={`#${heading.slug}`}>{heading.text}</a>
          </li>
        ))}
      </ol>
    </nav>
  )
}
