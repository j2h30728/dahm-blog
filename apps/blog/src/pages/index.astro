---
import PostList from "../components/PostList.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getPublishedPosts } from "../lib/posts";
import { ui } from "../lib/ui-classes";

const posts = await getPublishedPosts();
const featured = posts[0];
const tags = [...new Set(posts.flatMap((post) => post.data.tags))].sort();
const series = [...new Set(posts.map((post) => post.data.series))].sort();
const latestDate = featured?.data.date.toLocaleDateString("en", { month: "short", day: "numeric", year: "numeric" });
---
<BaseLayout title="Personal Tech Blog" description="Technical essays exported from an Obsidian-first workflow.">
  <section class={ui.homeIntro} aria-labelledby="home-title">
    <div class={ui.minWidthZero}>
      <p class={ui.tagline}>Obsidian-first publishing</p>
      <h1 id="home-title" class={ui.pageTitle}>Personal Tech Blog</h1>
      <p class={ui.pageSubtitle}>Technical essays on frontend architecture, publishing systems, and the boundaries that make engineering decisions easier to revisit.</p>
    </div>
    <div class={ui.homeSummary} aria-label="Blog summary">
      <span class={ui.summaryPill}>{posts.length} notes</span>
      <span class={ui.summaryPill}>{series.length} series</span>
      <span class={ui.summaryPill}>{tags.length} topics</span>
    </div>
  </section>

  {
    featured && (
      <section class={ui.latestStrip} aria-labelledby="latest-title">
        <div class={ui.latestGlow} aria-hidden="true"></div>
        <div class={ui.minWidthZero}>
          <p class={ui.tagline}>Latest essay</p>
          <h2 class={ui.latestTitle} id="latest-title">
            <a class={ui.latestLink} href={`/posts/${featured.data.slug}/`}>{featured.data.title}</a>
          </h2>
          <p class={ui.latestDescription}>{featured.data.description}</p>
        </div>
        <time class={ui.latestDate} datetime={featured.data.date.toISOString()}>{latestDate}</time>
      </section>
    )
  }

  <section class={ui.topicRail} aria-labelledby="topic-title">
    <div>
      <p class={ui.tagline}>Topics</p>
      <h2 class={ui.sectionTitle} id="topic-title">Follow a thread</h2>
    </div>
    <div class={ui.tagList}>
      {tags.map((tag) => <a class={ui.tagPill} href={`/tags/${tag}/`}>{tag}</a>)}
    </div>
  </section>

  <section class={ui.archiveSection} aria-labelledby="archive-title">
    <div class={ui.sectionHeading}>
      <p class={ui.tagline}>Archive</p>
      <h2 class={ui.sectionTitle} id="archive-title">Recent writing</h2>
    </div>
    <PostList posts={posts} />
  </section>
</BaseLayout>
