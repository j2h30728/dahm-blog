---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPublishedPosts } from "../../lib/posts";
import { slugify } from "../../lib/slug";

const posts = await getPublishedPosts();
const series = [...new Set(posts.map((post) => post.data.series))].sort();
---
<BaseLayout title="Series">
  <h1 class="page-title">Series</h1>
  <div class="post-list">
    {series.map((name) => (
      <article class="post-item">
        <a href={`/series/${slugify(name)}/`}>
          <h2>{name}</h2>
          <p>{posts.filter((post) => post.data.series === name).length} posts</p>
        </a>
      </article>
    ))}
  </div>
</BaseLayout>
