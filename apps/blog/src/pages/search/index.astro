---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { ui } from "../../lib/ui-classes";
---
<BaseLayout title="Search">
  <h1 class={ui.pageTitle}>Search</h1>
  <input class={ui.searchBox} id="search" type="search" placeholder="Search posts, tags, and series" autocomplete="off" />
  <div
    id="results"
    class={ui.postList}
    aria-live="polite"
    data-card={ui.postCard}
    data-card-link={ui.postCardLink}
    data-series={ui.postSeries}
    data-title={ui.postTitle}
    data-desc={ui.postDescription}
  ></div>
  <script>
    interface SearchPost {
      url: string;
      title: string;
      description: string;
      series: string;
      searchText: string;
    }

    const input = document.querySelector<HTMLInputElement>("#search");
    const results = document.querySelector<HTMLElement>("#results")!;
    const { card, cardLink, series: seriesCls, title: titleCls, desc } = results.dataset;
    const response = await fetch("/search/index.json");
    const posts: SearchPost[] = await response.json();

    function render(query: string) {
      const normalized = query.trim().toLowerCase();
      const matches = normalized
        ? posts.filter((post) => post.searchText.includes(normalized))
        : posts;

      results.innerHTML = matches
        .map((post) => `
          <article class="${card}">
            <a class="${cardLink}" href="${post.url}">
              <span class="${seriesCls}">${post.series}</span>
              <h2 class="${titleCls}">${post.title}</h2>
              <p class="${desc}">${post.description}</p>
            </a>
          </article>
        `)
        .join("");
    }

    if (input) {
      input.addEventListener("input", () => render(input.value));
    }
    render("");
  </script>
<script is:inline>
  (() => {
    const input = document.getElementById('search');
    if (!input || window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    const hints = [
      'Search posts...',
      "Try 'typescript'...",
      "Try 'openapi'...",
      "Try 'frontend'...",
      "Try 'react'...",
    ];

    let hintIdx = 0;
    let charIdx = 0;
    let deleting = false;
    let timer;

    function tick() {
      const current = hints[hintIdx];
      if (!deleting) {
        charIdx++;
        input.placeholder = current.slice(0, charIdx);
        if (charIdx === current.length) {
          deleting = true;
          timer = setTimeout(tick, 1800);
          return;
        }
        timer = setTimeout(tick, 62);
      } else {
        charIdx--;
        input.placeholder = current.slice(0, charIdx);
        if (charIdx === 0) {
          deleting = false;
          hintIdx = (hintIdx + 1) % hints.length;
          timer = setTimeout(tick, 380);
          return;
        }
        timer = setTimeout(tick, 32);
      }
    }

    input.placeholder = '';
    timer = setTimeout(tick, 700);
    input.addEventListener('focus', () => clearTimeout(timer));
  })();
</script>
</BaseLayout>
