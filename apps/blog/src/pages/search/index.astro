---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { ui } from "../../lib/ui-classes";
---
<BaseLayout title="Search">
  <h1 class={ui.pageTitle}>Search</h1>
  <input class={ui.searchBox} id="search" type="search" placeholder="Search posts, tags, and series" autocomplete="off" />
  <div id="results" class={ui.postList} aria-live="polite"></div>
  <script>
    interface SearchPost {
      url: string;
      title: string;
      description: string;
      series: string;
      searchText: string;
    }

    const input = document.querySelector<HTMLInputElement>("#search");
    const results = document.querySelector<HTMLElement>("#results");
    const response = await fetch("/search/index.json");
    const posts: SearchPost[] = await response.json();

    function render(query: string) {
      const normalized = query.trim().toLowerCase();
      const matches = normalized
        ? posts.filter((post) => post.searchText.includes(normalized))
        : posts;

      if (results) {
        results.innerHTML = matches
          .map((post) => `
            <article class="post-item rounded-xl border border-[var(--line)] bg-[var(--paper)] transition-[border-color,box-shadow,transform] duration-[240ms] ease-[var(--ease-spring)] hover:-translate-y-[3px] hover:border-[color-mix(in_srgb,var(--accent)_46%,var(--line))] hover:shadow-[var(--glow-md)]">
              <a class="block px-[22px] py-5 text-inherit hover:no-underline max-[640px]:p-[18px]" href="${post.url}">
                <span class="tracking-[0.08em] text-[var(--teal)]">${post.series}</span>
                <h2 class="mb-2 mt-0 block text-[clamp(1.22rem,2.6vw,1.56rem)] leading-[1.18] text-balance">${post.title}</h2>
                <p class="m-0 mb-4 max-w-[760px] text-[var(--muted-strong)]">${post.description}</p>
              </a>
            </article>
          `)
          .join("");
      }
    }

    if (input) {
      input.addEventListener("input", () => render(input.value));
    }
    render("");
  </script>
</BaseLayout>
