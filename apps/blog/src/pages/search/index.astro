---
import BaseLayout from "../../layouts/BaseLayout.astro";
---
<BaseLayout title="Search">
  <h1 class="page-title">Search</h1>
  <input class="search-box" id="search" type="search" placeholder="Search posts, tags, and series" autocomplete="off" />
  <div id="results" class="post-list" aria-live="polite"></div>
  <script>
    interface SearchPost {
      url: string;
      title: string;
      description: string;
      series: string;
      searchText: string;
    }

    const input = document.querySelector<HTMLInputElement>("#search");
    const results = document.querySelector<HTMLElement>("#results");
    const response = await fetch("/search/index.json");
    const posts: SearchPost[] = await response.json();

    function render(query: string) {
      const normalized = query.trim().toLowerCase();
      const matches = normalized
        ? posts.filter((post) => post.searchText.includes(normalized))
        : posts;

      if (results) {
        results.innerHTML = matches
          .map((post) => `
            <article class="post-item">
              <a href="${post.url}">
                <span>${post.series}</span>
                <h2>${post.title}</h2>
                <p>${post.description}</p>
              </a>
            </article>
          `)
          .join("");
      }
    }

    if (input) {
      input.addEventListener("input", () => render(input.value));
    }
    render("");
  </script>
</BaseLayout>
