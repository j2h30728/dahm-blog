---
import "../styles/global.css";
import ThemeToggle from "../components/ThemeToggle.astro";
import { ui } from "../lib/ui-classes";

const {
  title = "Personal Tech Blog",
  description = "Notes and technical essays.",
} = Astro.props as { title?: string; description?: string };
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light dark" />
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{title}</title>
    <script is:inline>
      const _s = localStorage.getItem('theme');
      document.documentElement.dataset.theme =
        _s === 'dark' || _s === 'light' ? _s
        : matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
    </script>
  </head>
  <body>
    <header class={ui.siteHeader}>
      <nav class={ui.nav} aria-label="Primary">
        <a class={ui.brand} href="/">
          <span class={ui.brandMark} aria-hidden="true"></span>
          Personal Tech Blog
        </a>
        <div class={ui.navLinks}>
          <a class={ui.navLink} href="/search/">Search</a>
          <a class={ui.navLink} href="/tags/">Tags</a>
          <a class={ui.navLink} href="/series/">Series</a>
          <ThemeToggle />
        </div>
      </nav>
    </header>
    <main class={ui.shell}>
      <slot />
    </main>
  </body>
</html>
