---
import "../styles/global.css";
import ThemeToggle from "../components/ThemeToggle.astro";
import { ui } from "../lib/ui-classes";

const {
  title = "Dahm",
  description = "담의 글과 기록을 모아둔 공간입니다.",
} = Astro.props as { title?: string; description?: string };
---
<!doctype html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light dark" />
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{title}</title>
    <script is:inline>
      const _s = localStorage.getItem('theme');
      document.documentElement.dataset.theme =
        _s === 'dark' || _s === 'light' ? _s
        : matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
    </script>
  </head>
  <body>
    <header class={ui.siteHeader}>
      <nav class={ui.nav} aria-label="Primary">
        <a class={ui.brand} href="/">
          <span class={ui.brandMark} aria-hidden="true"></span>
          Dahm
        </a>
        <div class={ui.navLinks}>
          <a class={ui.navLink} href="/about/">About</a>
          <a class={ui.navLink} href="/posts/">Posts</a>
          <a class={ui.navLink} href="/tags/">Tags</a>
          <a class={ui.navLink} href="/search/">Search</a>
          <ThemeToggle />
        </div>
      </nav>
    </header>
    <main class={ui.shell}>
      <slot />
    </main>
  </body>
  <script is:inline>
    (() => {
      const el = document.querySelector('.typewriter');
      if (!el) return;
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        el.classList.add('done');
        return;
      }
      const text = el.textContent.trim();
      el.textContent = '';
      let i = 0;
      function type() {
        if (i < text.length) {
          el.textContent += text[i++];
          setTimeout(type, 58);
        } else {
          el.classList.add('done');
        }
      }
      setTimeout(type, 350);
    })();
  </script>
</html>
