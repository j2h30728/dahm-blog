{
  "name": "dahm-blog-stack",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.34.4",
  "scripts": {
    "dev": "pnpm sync:content && pnpm --filter @dahm-blog/blog dev",
    "sync:content": "pnpm --filter @dahm-blog/content-sync sync",
    "sync:next-content": "pnpm --filter @dahm-blog/content-sync sync -- --out apps/next-blog/src/content/posts --assets apps/next-blog/public/post-assets --manifest .content-sync/next-publish-manifest.json --public-index apps/next-blog/src/content/public-link-index.json --public-graph-index apps/next-blog/src/content/public-graph-index.json --public-tag-index apps/next-blog/src/content/public-tag-index.json --public-post-index apps/next-blog/src/content/public-post-index.json --search-index apps/next-blog/public/search/index.json --post-module-map apps/next-blog/src/content/post-module-map.ts --jsx-attributes",
    "index:private": "pnpm --filter @dahm-blog/private-wiki-index index",
    "test": "pnpm --filter @dahm-blog/content-sync test && pnpm --filter @dahm-blog/private-wiki-index test && pnpm --filter @dahm-blog/blog test",
    "test:next-blog": "pnpm sync:next-content && pnpm --filter @dahm-blog/next-blog test",
    "build:blog": "pnpm --filter @dahm-blog/blog build",
    "build:next-blog": "pnpm sync:next-content && pnpm --filter @dahm-blog/next-blog build",
    "build": "pnpm --filter @dahm-blog/content-sync build && pnpm sync:content && pnpm --filter @dahm-blog/private-wiki-index build && pnpm index:private && pnpm --filter @dahm-blog/blog build",
    "typecheck": "pnpm --filter @dahm-blog/content-sync typecheck && pnpm --filter @dahm-blog/private-wiki-index typecheck && pnpm --filter @dahm-blog/blog typecheck",
    "typecheck:next-blog": "pnpm sync:next-content && pnpm --filter @dahm-blog/next-blog typecheck",
    "dev:next-blog": "pnpm sync:next-content && pnpm --filter @dahm-blog/next-blog dev"
  },
  "engines": {
    "node": "24.x"
  },
  "devDependencies": {
    "@types/node": "^24.0.4",
    "typescript": "^5.8.3"
  },
  "volta": {
    "node": "24.17.0"
  }
}
